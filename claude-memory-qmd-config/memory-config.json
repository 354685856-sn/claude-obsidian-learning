{
  "memory": {
    "backend": "qmd",
    "citations": "auto",
    "qmd": {
      "includeDefaultMemory": true,
      "update": {
        "interval": "5m",
        "debounceMs": 15000,
        "onBoot": true,
        "waitForBootSync": false
      },
      "limits": {
        "maxResults": 10,
        "maxSnippetChars": 1000,
        "maxInjectedChars": 5000,
        "timeoutMs": 5000
      },
      "scope": {
        "default": "allow",
        "rules": []
      },
      "paths": [
        {
          "name": "long-term",
          "path": "/Users/mac/bin/.claude/memory/MEMORY.md",
          "pattern": "*.md"
        },
        {
          "name": "daily",
          "path": "/Users/mac/bin/.claude/memory/daily",
          "pattern": "**/*.md"
        },
        {
          "name": "work-progress",
          "path": "/Users/mac/bin/.claude/work-progress.md",
          "pattern": "*.md"
        }
      ],
      "sessions": {
        "enabled": true,
        "retentionDays": 30
      }
    },
    "query": {
      "hybrid": {
        "enabled": true,
        "vectorWeight": 0.7,
        "textWeight": 0.3,
        "candidateMultiplier": 4,
        "mmr": {
          "enabled": true,
          "lambda": 0.7
        },
        "temporalDecay": {
          "enabled": true,
          "halfLifeDays": 30
        }
      }
    }
  }
}
